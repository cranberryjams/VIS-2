{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Density of match team-scores by 5-year era, all overlaid on a single x-axis with a gold-to-green time gradient — makes era-to-era differences in mode position and tail thickness directly comparable.",
  "width": 1000,
  "height": 460,
  "data": {
    "url": "datasets/match_data.csv",
    "format": {
      "type": "csv",
      "parse": {
        "date": "date",
        "home_team_score": "number",
        "away_team_score": "number",
        "crowd": "number"
      }
    }
  },
  "transform": [
    { "filter": "datum.competition == 'NRL' && isValid(datum.home_team_score) && isValid(datum.away_team_score)" },
    { "calculate": "year(datum.date)", "as": "season" },
    {
      "fold": ["home_team_score", "away_team_score"],
      "as": ["which", "score"]
    },
    {
      "calculate": "datum.season < 2003 ? '1998–2002' :datum.season < 2008 ? '2003–2007' :datum.season < 2013 ? '2008–2012' :datum.season < 2018 ? '2013–2017' :datum.season < 2023 ? '2018–2022' : '2023–2025'",
      "as": "era"
    },
    {
      "density": "score",
      "groupby": ["era"],
      "extent": [0, 70],
      "steps": 70,
      "as": ["score_val", "density"]
    }
  ],
  "mark": {
    "type": "line",
    "interpolate": "monotone",
    "strokeWidth": 3.2,
    "opacity": 0.95
  },
  "encoding": {
    "x": {
      "field": "score_val",
      "type": "quantitative",
      "title": "Points scored in a match",
      "scale": { "domain": [0, 70] },
      "axis": { "grid": false }
    },
    "y": {
      "field": "density",
      "type": "quantitative",
      "title": "Density",
      "axis": null
    },
    "color": {
      "field": "era",
      "type": "ordinal",
      "sort": [
        "1998–2002",
        "2003–2007",
        "2008–2012",
        "2013–2017",
        "2018–2022",
        "2023–2025"
      ],
      "scale": {
        "range": [
          "#c8a14a",
          "#a89a3f",
          "#7d9b3a",
          "#4d8540",
          "#1d6e38",
          "#003d1f"
        ]
      },
      "title": "Era",
      "legend": {
        "orient": "right",
        "labelFontSize": 12,
        "titleFontSize": 12,
        "symbolType": "stroke",
        "symbolStrokeWidth": 4,
        "rowPadding": 6
      }
    },
    "tooltip": [
      { "field": "era", "title": "Era" },
      { "field": "score_val", "title": "Score", "format": ".0f" },
      { "field": "density", "title": "Density", "format": ".3f" }
    ]
  },
  "config": {
    "view": { "stroke": null }
  }
}
