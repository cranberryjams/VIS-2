{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Average points scored per team per match by season, shown as two lines (home and away) with the gap between them shaded to emphasise the home-ground edge.",
  "width": 460,
  "height": 280,
  "data": {
    "url": "datasets/match_data.csv",
    "format": {
      "type": "csv",
      "parse": {
        "date": "date",
        "home_team_score": "number",
        "away_team_score": "number",
        "crowd": "number"
      }
    }
  },
  "transform": [
    { "filter": "datum.competition == 'NRL'" },
    { "calculate": "year(datum.date)", "as": "season" },
    {
      "aggregate": [
        { "op": "mean", "field": "home_team_score", "as": "Home" },
        { "op": "mean", "field": "away_team_score", "as": "Away" }
      ],
      "groupby": ["season"]
    },
    { "calculate": "min(datum.Home, datum.Away)", "as": "lo" },
    { "calculate": "max(datum.Home, datum.Away)", "as": "hi" }
  ],
  "resolve": { "scale": { "y": "shared" } },
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#006633",
        "opacity": 0.12,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "season",
          "type": "quantitative",
          "title": "Season",
          "axis": { "format": "d", "tickCount": 7 }
        },
        "y": {
          "field": "lo",
          "type": "quantitative",
          "title": "Avg points per team per match",
          "scale": { "zero": false, "nice": true }
        },
        "y2": { "field": "hi" }
      }
    },
    {
      "transform": [
        { "fold": ["Home", "Away"], "as": ["venue", "mean_pts"] }
      ],
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 2.5,
        "point": { "filled": true, "size": 35 }
      },
      "encoding": {
        "x": {
          "field": "season",
          "type": "quantitative"
        },
        "y": {
          "field": "mean_pts",
          "type": "quantitative",
          "scale": { "zero": false, "nice": true }
        },
        "color": {
          "field": "venue",
          "type": "nominal",
          "scale": {
            "domain": ["Home", "Away"],
            "range": ["#006633", "#c8a14a"]
          },
          "title": null,
          "legend": { "orient": "top" }
        },
        "tooltip": [
          { "field": "season", "title": "Season", "format": "d" },
          { "field": "venue", "title": "Side" },
          { "field": "mean_pts", "title": "Avg points", "format": ".1f" }
        ]
      }
    }
  ]
}
